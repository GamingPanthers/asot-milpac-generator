# Node Environment
NODE_ENV=production

# Server Configuration
PORT=3000
IMAGE_OUTPUT_DIR=./milpac
IMAGE_SERVICE_URL=http://localhost:3000

# Webhook Security
# Generate a secure key: openssl rand -base64 32
WEBHOOK_API_KEY=your_secure_api_key_here_change_this_in_production

# MongoDB Configuration
# Connection string with connection pooling (maxPoolSize=10, minPoolSize=2)
MONGO_USERNAME=admin
MONGO_PASSWORD=change_this_password_in_production
MONGODB_URI=mongodb://admin:change_this_password_in_production@mongodb:27017/milpac?authSource=admin&maxPoolSize=10&minPoolSize=2&maxIdleTimeMS=45000&retryWrites=true&journal=true

# Redis Configuration
REDIS_URL=redis://redis:6379

# Web Integration
WEB_SERVICE_URL=http://localhost:3001

# Image Generation
IMAGE_WIDTH=1398
IMAGE_HEIGHT=1000

# Job Queue Configuration
MAX_RETRIES=5
JOB_TIMEOUT=30000
MAX_CONCURRENT_JOBS=5

# Performance & Caching
# Query cache TTL in milliseconds (default: 5 minutes)
QUERY_CACHE_TTL=300000
# Slow query threshold in milliseconds
SLOW_QUERY_THRESHOLD_MS=100

# Logging
LOG_LEVEL=info

# API Configuration
API_TIMEOUT=30000

